{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.ora-studio.app" }],
      "destination": "https://ora-studio.app/:path*",
      "permanent": true
    }
  ]
}
